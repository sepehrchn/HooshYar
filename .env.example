# Site Configuration
NEXT_PUBLIC_SITE_URL=https://hoosh-yar.com

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH_BASE64=your-bcrypt-hash-base64-encoded-here

# Groq API (Chatbot)
GROQ_API_KEY=your-groq-api-key-here

# Email (Contact Form)
RESEND_API_KEY=your-resend-api-key-here
CONTACT_TO_EMAIL=your-email@example.com
CONTACT_FROM_EMAIL=your-website@example.com

# Vercel KV (Optional - for logging and content management)
KV_REST_API_URL=https://your-kv-rest-url.kv.vercel.net
KV_REST_API_TOKEN=your-kv-rest-api-token-here